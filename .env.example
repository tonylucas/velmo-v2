# Azure AI Inference (Kimi-K2.6)
AZURE_AI_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_INFERENCE_API_KEY=your-azure-ai-inference-key-here
AZURE_AI_INFERENCE_MODEL=Kimi-K2.6

# Base relationnelle (état conversationnel et préférences)
DB_URL=postgresql+psycopg://app:app@localhost:5432/velmo

# Base vectorielle (mémoire long terme épisodique)
CHROMA_URL=http://localhost:8001
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Seuil de note bloquant en CI
EVAL_MIN_SCORE=0.8

# Garde-fous prod : Azure AI Content Safety (sinon détection déterministe locale)
AZURE_CONTENT_SAFETY_ENDPOINT=
# Clé Content Safety ; à défaut, AZURE_AI_INFERENCE_API_KEY est réutilisée.
AZURE_CONTENT_SAFETY_KEY=
